# ========================
# SERVER CONFIGURATION
# ========================
PORT=5000

# Environment: development or production
NODE_ENV=development
# NODE_ENV=production

# ========================
# RATE LIMITING CONFIGURATION (Production Settings)
# ========================
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX_REQUESTS=1000

# ========================
# DATABASE CONFIGURATION
# ========================
# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?ssl=true&replicaSet=<replica>&authSource=admin&appName=<app>
# IMPORTANT: Replace with your actual MongoDB Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/NOVAA?ssl=true&replicaSet=atlas-shard-0&authSource=admin&appName=Cluster0

# ========================
# JWT SECURITY
# ========================
# CRITICAL: Generate a strong random key for production!
# Command: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum: 64 characters recommended
JWT_SECRET=<generate-strong-random-key-min-64-chars>

# JWT Token Expiry
JWT_ACCESS_EXPIRY=2hr
JWT_REFRESH_EXPIRY=7d

# ========================
# SUPER ADMIN CREDENTIALS
# ========================
# IMPORTANT: Use strong passwords in production!
SUPER_ADMIN_EMAIL=superadmin@smartcollege.com
SUPER_ADMIN_PASSWORD=<strong-password-min-12-chars>

# ========================
# ENCRYPTION MASTER KEY
# ========================
# CRITICAL FOR MULTI-TENANT PAYMENTS
# This key encrypts/decrypts college-specific payment gateway secrets
# MUST be at least 32 characters (64+ recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If lost, all encrypted payment credentials become unrecoverable!
ENCRYPTION_MASTER_KEY=<generate-strong-random-key-min-64-chars>

# ========================
# FRONTEND URL CONFIGURATION
# ========================
# Development: http://localhost:5173
# Production: https://yourdomain.com
# Used for: Payment redirects, email links, CORS
FRONTEND_URL=http://localhost:5173

# ========================
# EMAIL CONFIGURATION
# ========================
# Gmail SMTP Settings
# IMPORTANT: Use Gmail App Password (not your main password)
# Generate: https://myaccount.google.com/apppasswords
# Steps: Enable 2FA → Create App Password → Use 16-char password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=<gmail-app-password-16-chars>

# ========================
# CORS CONFIGURATION
# ========================
# Comma-separated list of allowed origins
# Development: http://localhost:5173,http://localhost:5174,http://localhost:3000
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
CLIENT_URL=http://localhost:5173

# ========================
# PAYMENT GATEWAYS (Multi-Tenant)
# ========================
# IMPORTANT: For multi-tenant SaaS, DO NOT use global keys here!
# Each college configures their own Stripe/Razorpay credentials via Admin Dashboard
# These global keys are COMMENTED OUT for security
# Only uncomment if you're using single-tenant mode (not recommended)

# Stripe (Global Fallback - COMMENTED OUT for multi-tenant)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay (Global Fallback - COMMENTED OUT for multi-tenant)
# RAZORPAY_KEY_ID=rzp_test_your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# ========================
# TEST CREDENTIALS (Development Only)
# ========================
# These are used for API testing (backend/test.js)
# DO NOT use production credentials for testing!
TEST_SUPER_ADMIN_EMAIL=superadmin@smartcollege.com
TEST_SUPER_ADMIN_PASSWORD=<test-password>
TEST_COLLEGE_ADMIN_EMAIL=collegeadmin@example.com
TEST_COLLEGE_ADMIN_PASSWORD=<test-password>

# ========================
# SECURITY NOTES
# ========================
# 1. NEVER commit .env to version control (it's in .gitignore)
# 2. Use strong, randomly generated secrets for production
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use environment-specific .env files (.env.development, .env.production)
# 5. Store production secrets in secure vault (AWS Secrets Manager, etc.)
