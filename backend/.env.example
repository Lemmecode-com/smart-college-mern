# ========================
# SERVER CONFIGURATION
# ========================
PORT=5000
NODE_ENV=development

# ========================
# DATABASE
# ========================
MONGODB_URI=mongodb://localhost:27017/smart-college

# ========================
# JWT SECURITY
# ========================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiry for different roles (default: 1d)
# Format: number + unit (s=seconds, m=minutes, h=hours, d=days)
JWT_STUDENT_EXPIRY=1d
JWT_TEACHER_EXPIRY=1d
JWT_ADMIN_EXPIRY=1d
JWT_SUPER_ADMIN_EXPIRY=1d

# ========================
# SUPER ADMIN CREDENTIALS
# ========================
# ⚠️ IMPORTANT: These are EXAMPLE values only!
# DO NOT use these example values in production!
# Replace with your own secure credentials in .env file before running seed script.
# The .env file is in .gitignore and will NOT be committed to Git (secure).
#
# After copying .env.example to .env:
# 1. Change SUPER_ADMIN_EMAIL to your actual admin email
# 2. Change SUPER_ADMIN_PASSWORD to a strong password (min 8 chars, uppercase, lowercase, number, special char)
# 3. Run: npm run seed:super-admin
# 4. Verify login works with your credentials
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!@#

# ========================
# EMAIL CONFIGURATION
# ========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Smart College <noreply@smartcollege.com>
SUPPORT_EMAIL=support@college.edu

# ========================
# FRONTEND URL CONFIGURATION
# ========================
# IMPORTANT: Set this to your production domain when deploying
# Examples:
#   Development: FRONTEND_URL=http://localhost:5173
#   Production: FRONTEND_URL=https://yourdomain.com
#   With port: FRONTEND_URL=https://yourdomain.com:3000
# This URL is used for:
#   - Email links (approval, rejection, password reset, etc.)
#   - Redirect URLs after authentication
#   - Any system-generated emails with login links
FRONTEND_URL=http://localhost:5173

# ========================
# CORS CONFIGURATION
# ========================
CLIENT_URL=http://localhost:5173

# ========================
# PAYMENT GATEWAYS
# ========================
# Global Stripe keys (fallback for legacy/single-tenant mode)
# For multi-tenant SaaS, colleges configure their own Stripe keys via Admin Dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay (global fallback)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ========================
# ENCRYPTION MASTER KEY
# ========================
# ⚠️ CRITICAL FOR MULTI-TENANT PAYMENTS
# This key is used to encrypt/decrypt college-specific payment gateway secrets
# MUST be at least 16 characters long
# Store this securely - if lost, all encrypted payment credentials will be unrecoverable
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your-super-secret-encryption-key-min-16-chars

# ========================
# FILE UPLOAD
# ========================
MAX_FILE_SIZE=5242880
# 5MB in bytes

# ========================
# RATE LIMITING
# ========================
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes

# ================= COLLEGE CONFIGURATION =================
# Default attendance threshold for alerts (percentage)
MINIMUM_ATTENDANCE_THRESHOLD=75

# ================= CORS ORIGINS (Comma separated) =================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ================= RATE LIMITING =================
# Window duration in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window (default: 100)
# In development: 100 requests/minute
# In production: 100 requests/15 minutes
RATE_LIMIT_MAX_REQUESTS=1000

# ================= LOGGING =================
# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# ================= TEST CREDENTIALS =================
# These are used for API testing (backend/test.js)
# DO NOT use production credentials for testing!
TEST_SUPER_ADMIN_EMAIL=superadmin@smartcollege.com
TEST_SUPER_ADMIN_PASSWORD=YourSuperAdminPassword
TEST_COLLEGE_ADMIN_EMAIL=collegeadmin@example.com
TEST_COLLEGE_ADMIN_PASSWORD=YourCollegeAdminPassword
